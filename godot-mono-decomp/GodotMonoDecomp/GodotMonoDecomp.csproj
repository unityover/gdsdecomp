<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Library</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>GodotMonoDecomp</RootNamespace>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>
    <ItemGroup>
      <PackageReference Include="ICSharpCode.Decompiler" Version="10.0.0.8323-preview3" />
      <PackageReference Include="ICSharpCode.ILSpyX" Version="10.0.0.8323-preview3" />
      <PackageReference Include="NuGet.Packaging" Version="6.14.0" />
    </ItemGroup>

</Project>
